{
  "name": "savio-backend",
  "version": "1.0.0",
  "description": "Savio API - Price comparison backend with PostgreSQL and Redis",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:migrate": "prisma migrate dev",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"src/**/*.ts\" \"prisma/**/*.ts\"",
    "stress-test": "tsx stress-test.ts",
    "test:parser": "tsx src/parsers/__tests__/zepto.parser.test.ts"
  },
  "keywords": [
    "savio",
    "price-comparison",
    "grocery",
    "api"
  ],
  "author": "Savio Team",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@prisma/client": "^5.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.6",
    "prisma": "^5.8.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
